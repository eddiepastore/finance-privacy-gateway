# Copy to .env and fill in to use a real OpenAI-compatible model instead of the deterministic mock.
# The gateway never puts these (or any real financials) into the LLM packet — they only authenticate
# the outbound call that carries the already-obfuscated packet.

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
GATEWAY_MODEL=gpt-4o-mini

# Run with:  python3 scripts/run_demo.py --llm auto
